{
  "name": "kastell-plugin-auditor",
  "version": "1.1.0",
  "apiVersion": "1",
  "kastell": ">=2.2.0",
  "capabilities": ["audit", "command", "mcp-tool"],
  "checkPrefix": "AUD",
  "entry": "index.js",
  "commands": [
    {
      "name": "analyze",
      "description": "Analyze audit results with recommendations",
      "handler": "./commands/analyze.js"
    }
  ],
  "mcpTools": [
    {
      "name": "report",
      "description": "Generate audit summary report for a server",
      "handler": "./mcp/report.js"
    }
  ]
}