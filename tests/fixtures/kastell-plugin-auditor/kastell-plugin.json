{
  "name": "kastell-plugin-auditor",
  "version": "0.1.0",
  "apiVersion": "2",
  "kastell": ">=2.0.0",
  "capabilities": ["audit", "fix"],
  "checkPrefix": "AUDT",
  "entry": "index.js",
  "fixes": [
    {
      "checkId": "AUDT-SAMPLE-FIX",
      "tier": "SAFE",
      "handler": "./fixes/sample-fix.js",
      "backupPaths": ["/etc/kastell-test.conf"]
    }
  ]
}
